{
  "name": "template-analysis",
  "version": "1.0.0",
  "author": "Tago LLC",
  "license": "Copyright",
  "private": true,
  "scripts": {
    "linter": "eslint .",
    "linter-fix": "eslint --fix .",
    "deploy": "ts-node ./src/deploy/upload.ts",
    "inspector": "ts-node ./src/deploy/device-live-inspector.ts.ts",
    "console": "ts-node ./src/deploy/analysis-console.ts",
    "duplicate": "ts-node ./src/deploy/duplicate-analysis.ts",
    "trigger": "ts-node ./src/deploy/trigger-analysis.ts",
    "debug": "ts-node-dev src/analysis/analysisHandler --inspect",
    "test": "jest . --"
  },
  "jest": {
    "preset": "ts-jest"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run test",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "devDependencies": {
    "@types/jest": "29.4.0",
    "@types/luxon": "3.2.0",
    "@typescript-eslint/eslint-plugin": "5.49.0",
    "@typescript-eslint/parser": "5.49.0",
    "commitlint": "17.4.2",
    "eslint": "8.32.0",
    "eslint-config-prettier": "8.6.0",
    "eslint-import-resolver-typescript": "3.5.3",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-prettier": "4.2.1",
    "husky": "8.0.3",
    "jest": "29.4.0",
    "prettier": "2.8.3",
    "ts-jest": "29.0.5",
    "ts-node": "10.9.1",
    "ts-node-dev": "2.0.0",
    "typescript": "4.9.4"
  },
  "dependencies": {
    "@tago-io/builder": "3.1.3",
    "@tago-io/sdk": "10.10.0",
    "dayjs": "1.11.7",
    "moment-timezone": "0.5.40",
    "puppeteer": "19.6.0",
    "zod": "3.20.6"
  }
}
